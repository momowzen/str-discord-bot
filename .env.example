# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application ID (right sidebar in Developer Portal)
CLIENT_ID=your_application_id_here

# Default language when none is configured
DEFAULT_LANG=en

# Turso database (optional — for persistent storage on Railway)
# Create a free database at https://turso.tech
# TURSO_URL=libsql://str-discord-bot-username.turso.io
# TURSO_TOKEN=your_turso_auth_token
